<?xml version="1.0" ?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.4.1">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Auto Test">
      <stringProp name="TestPlan.comments"/>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
    </TestPlan>
    <hashTree/>
    <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="CSV Data Set Config">
      <stringProp name="filename">data.csv</stringProp>
      <stringProp name="fileEncoding"/>
      <stringProp name="variableNames">u,p</stringProp>
      <stringProp name="delimiter">,</stringProp>
      <boolProp name="quotedData">false</boolProp>
      <boolProp name="recycle">true</boolProp>
      <boolProp name="stopThread">false</boolProp>
    </CSVDataSet>
    <hashTree/>
    <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Constant Timer 150ms">
      <stringProp name="ConstantTimer.delay">150</stringProp>
    </ConstantTimer>
    <hashTree/>
    <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Regex Extractor">
      <stringProp name="RegexExtractor.useHeaders">false</stringProp>
      <stringProp name="RegexExtractor.refname">token</stringProp>
      <stringProp name="RegexExtractor.regex">token=(\w+)</stringProp>
      <stringProp name="RegexExtractor.template">$1$</stringProp>
      <stringProp name="RegexExtractor.match_number">1</stringProp>
      <stringProp name="RegexExtractor.default"/>
    </RegexExtractor>
    <hashTree/>
  </hashTree>
</jmeterTestPlan>
